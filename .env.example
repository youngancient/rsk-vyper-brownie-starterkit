# .env.example
# DO NOT commit your actual .env file to GitHub!

# Your wallet's private key (must start with 0x)
PRIVATE_KEY=0x...

# Override default public RPCs with your own (e.g., from dRPC, Alchemy, or Tatum)
RSK_TESTNET_RPC=https://public-node.testnet.rsk.co
RSK_MAINNET_RPC=https://public-node.rsk.co

# Required for contract verification on Blockscout
BLOCKSCOUT_API_KEY=your_blockscout_api_key_here